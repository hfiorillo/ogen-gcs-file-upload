@baseUrl = http://localhost:8080
# Base64("admin:password")
@authOk = Basic YWRtaW46cGFzc3dvcmQ=

### Upload JSON (expected 400 bad request)
# @name upload_json_rejected
POST {{baseUrl}}/upload
Authorization: {{authOk}}
Content-Type: multipart/form-data; boundary=tp-boundary

--tp-boundary
Content-Disposition: form-data; name="file"; filename="big.json"
Content-Type: application/json

< ./fixtures/big.json
--tp-boundary--

> {%
client.test("json upload returns 400", () => {
  client.assert(response.status === 400, `Expected 400 but got ${response.status}`);
});

client.test("json upload error payload is shaped", () => {
  client.assert(response.parsedBody.code === 400, "expected error code 400");
});
%}
